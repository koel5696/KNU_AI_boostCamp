rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /guestbook/{entryId} {
      allow read: if true;
      allow create: if isValidGuestbookEntry();
      allow delete: if isAdmin();
      allow update: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function isValidGuestbookEntry() {
  let data = request.resource.data;

  return data.keys().hasOnly(['name', 'message', 'createdAt'])
    && data.name is string
    && data.name.size() > 0
    && data.name.size() <= 24
    && data.message is string
    && data.message.size() > 0
    && data.message.size() <= 300
    && data.createdAt == request.time;
}

function isAdmin() {
  return request.auth != null
    && request.auth.token.email == 'doeysa1234@gmail.com';
}
